{
  "name": "goddest-metals",
  "version": "1.0.0",
  "description": "Professional Silver Transaction Management Software for Goddest Metals Company",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "build:electron": "vite build && electron-builder --win --x64",
    "build:portable": "vite build && electron-builder --win portable --x64",
    "preview": "vite preview",
    "electron": "electron ."
  },
  "dependencies": {
    "sql.js": "^1.12.0",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.4.2",
    "react-chartjs-2": "^5.2.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.22.3",
    "react-table": "^7.8.0",
    "date-fns": "^3.6.0",
    "xlsx": "^0.18.5",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "archiver": "^7.0.0",
    "extract-zip": "^2.0.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^25.1.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.2.0",
    "vite-plugin-electron": "^0.28.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.goddestmetals.app",
    "productName": "Goddest Metals",
    "copyright": "Copyright © 2024 Goddest Metals Company",
    "asar": true,
    "directories": {
      "output": "dist-electron",
      "buildResources": "public"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "public/**/*",
      "!node_modules/.cache/**/*",
      "!node_modules/.bin/**/*",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        },
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "public/logo02.png",
      "requestedExecutionLevel": "asInvoker",
      "signingHashAlgorithms": null,
      "sign": null
    },
    "portable": {
      "artifactName": "Goddest Metals ${version}.exe",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Goddest Metals",
      "runAfterFinish": true,
      "artifactName": "Goddest Metals Setup ${version}.exe"
    },
    "publish": null
  }
}
